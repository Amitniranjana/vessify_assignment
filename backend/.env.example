# Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/finance_extractor?schema=public"

# Auth Secrets
BETTER_AUTH_SECRET="your_generated_secret_here"

# In development, this is http://localhost:8080. In production, set to your Render/Railway backend URL.
BETTER_AUTH_URL="http://localhost:8080"

# In development, this is http://localhost:3000. In production, set to your Vercel frontend URL for CORS.
FRONTEND_URL="http://localhost:3000"

PORT=8080
